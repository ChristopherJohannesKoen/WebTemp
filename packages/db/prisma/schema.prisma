generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  name                String
  passwordHash        String
  role                Role                 @default(member)
  bootstrapOwnership  BootstrapState?      @relation("BootstrapOwner")
  sessions            Session[]
  passwordResetTokens PasswordResetToken[]
  auditLogs           AuditLog[]           @relation("AuditActor")
  createdProjects     Project[]            @relation("ProjectCreator")
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}

model BootstrapState {
  id               Int      @id @default(1)
  bootstrapOwnerId String   @unique
  bootstrapOwner   User     @relation("BootstrapOwner", fields: [bootstrapOwnerId], references: [id], onDelete: Restrict)
  completedAt      DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Session {
  id             String   @id @default(cuid())
  tokenHash      String   @unique
  csrfTokenHash  String
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt      DateTime
  createdAt      DateTime @default(now())
  lastUsedAt     DateTime @default(now())
  lastRotatedAt  DateTime @default(now())
  ipAddress      String?
  userAgent      String?

  @@index([userId])
  @@index([expiresAt])
  @@index([lastRotatedAt])
}

model PasswordResetToken {
  id         String    @id @default(cuid())
  tokenHash  String    @unique
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model AuditLog {
  id         String    @id @default(cuid())
  actorId    String?
  actor      User?     @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  action     String
  targetType String
  targetId   String?
  metadata   Json?
  createdAt  DateTime  @default(now())

  @@index([actorId])
  @@index([targetType, targetId])
  @@index([createdAt])
}

model IdempotencyRequest {
  id                 String            @id @default(cuid())
  scope              String
  idempotencyKey     String
  method             String
  path               String
  fingerprint        String
  status             IdempotencyStatus @default(pending)
  responseStatusCode Int?
  responseBody       Json?
  expiresAt          DateTime
  completedAt        DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@unique([scope, idempotencyKey, method, path])
  @@index([expiresAt])
}

model Project {
  id          String        @id @default(cuid())
  name        String
  description String?
  status      ProjectStatus @default(active)
  isArchived  Boolean       @default(false)
  creatorId   String
  creator     User          @relation("ProjectCreator", fields: [creatorId], references: [id], onDelete: Restrict)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([status])
  @@index([isArchived])
  @@index([creatorId])
  @@index([updatedAt, id])
}

enum Role {
  owner
  admin
  member
}

enum ProjectStatus {
  active
  paused
  completed
}

enum IdempotencyStatus {
  pending
  completed
}
